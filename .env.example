# Copy to .env and fill in. Only the active provider's key is required
# (DEEPSEEK_API_KEY, or GIGACHAT_CREDENTIALS if LLM_PROVIDER=gigachat);
# everything else has the default shown below. Values are validated at startup.

# ── LLM provider switch (general_settings) ──
LLM_PROVIDER=deepseek                     # deepseek / gigachat — both stacks below stay configured; this picks which one runs

# ── DeepSeek API (general_settings) ──
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_CONNECTION_RETRIES=3             # tenacity retries on 429/5xx/connection drops (0 disables)
DEEPSEEK_RETRY_BACKOFF_FACTOR=1.0         # initial backoff seconds, doubles per retry (cap 60s); 429 Retry-After honored

# ── GigaChat API (general_settings) ──
GIGACHAT_CREDENTIALS=...                  # base64 authorization key from developers.sber.ru (auto-exchanged for a 30-min token)
GIGACHAT_SCOPE=GIGACHAT_API_PERS          # GIGACHAT_API_PERS / GIGACHAT_API_B2B / GIGACHAT_API_CORP
GIGACHAT_MODEL=GigaChat-2-Pro             # freshest API-available flagship (Ultra is chat-only for now)
GIGACHAT_BASE_URL=https://gigachat.devices.sberbank.ru/api/v1
GIGACHAT_VERIFY_SSL_CERTS=false           # API certs are from the RU Ministry CA; install it and set true to verify
GIGACHAT_CONNECTION_RETRIES=3             # tenacity retries on 429/5xx/connection drops (0 disables)
GIGACHAT_RETRY_BACKOFF_FACTOR=1.0         # initial backoff seconds, doubles per retry (cap 60s); 429 Retry-After honored

# ── Agent loop (general_settings) ──
MAX_ITERATIONS=3                          # max search→check retries before give_up
STRUCTURED_MAX_RETRIES=1                   # re-prompts on a schema-validation failure before give_up (0 disables)

# ── Vector DB (vdb_settings) ──
LANCE_DB_PATH=./data/lancedb/_cli         # CLI/global DB dir (web overrides per project)
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2   # multilingual (RU+), 384d; changing model -> full reindex
EMBEDDING_CACHE_DIR=./data/fastembed_cache  # where the ~252MB ONNX model lives (FastEmbed's default /tmp is wiped on reboot)
CHUNK_SIZE=1000                           # chunk target, chars (new docs only)
CHUNK_OVERLAP=150                         # chunk overlap, chars
DESCRIPTIONS_ENABLED=true                 # LLM file summary at index time + Planner uses it for routing
DESCRIBE_MAX_CHARS=6000                    # leading chars of each file sent to the LLM for its description
INDEX_CONCURRENCY=3                       # files processed concurrently by the indexer
SEARCH_TOP_K=5                            # nearest chunks per (collection, query) before stitching
HYBRID_SEARCH_ENABLED=true                # fuse vector KNN with full-text (BM25-style) search via RRF; needs a reindex to build the FTS index if flipped on for an existing project

# ── OCR (vdb_settings) — default is LiteParse's built-in Tesseract (works out of the box) ──
# Optional: for better Cyrillic + no "Image too small" noise, run a local OCR
# sidecar and uncomment the lines below. Clone the liteparse repo and, from its
# ocr/ dir, `uv run server.py` (EasyOCR :8828 / PaddleOCR :8829).
# Unset/empty OCR_SERVER_URL → built-in Tesseract.
# OCR_SERVER_URL=http://localhost:8828/ocr  # EasyOCR sidecar (PaddleOCR → :8829)
# OCR_LANGUAGE=ru                           # language code forwarded to the sidecar

# ── Neighbor stitching (vdb_settings) ──
EXPAND_PADDING=1                          # window [seq-P, seq+P] around each hit
BRIDGE_GAP=2                              # merge windows when the uncovered gap <= this
MAX_EXPANDED=16                           # cap on stitched chunks per result
